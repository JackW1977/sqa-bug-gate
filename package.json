{
  "name": "Software-bug-gate",
  "version": "1.0.0",
  "description": "Software Bug Gate — Jira Forge app enforcing Noah Medical Software bug-report quality standards",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "deploy": "forge deploy",
    "install:app": "forge install"
  },
  "dependencies": {
    "@forge/api": "^4.0.0",
    "@forge/resolver": "^1.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
