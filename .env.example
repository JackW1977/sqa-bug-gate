# ─── Jira credentials (required) ─────────────────────────────────────────────
# Your Jira cloud hostname, e.g. yourcompany.atlassian.net
JIRA_HOST=noahmed.atlassian.net

# The email address you log into Jira with
JIRA_EMAIL=your-email@yourcompany.com

# Jira API token — generate one at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your-jira-api-token

# ─── Glean AI (optional — enables ✨ Rephrase with Glean buttons) ─────────────
# Your Glean API token
GLEAN_TOKEN=your-glean-api-token

# Your Glean backend base URL, e.g. https://yourcompany-be.glean.com
GLEAN_BASE_URL=https://yourcompany-be.glean.com

# ─── Server port (optional, default 4400) ────────────────────────────────────
PORT=8080
