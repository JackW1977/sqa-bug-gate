# Jira connection
JIRA_HOST=yourcompany.atlassian.net
JIRA_EMAIL=your-email@yourcompany.com
JIRA_TOKEN=your-jira-api-token

# Glean AI (optional) - enables the ✨ Rephrase with Glean button on all text fields
# Get a token from your Glean admin: company.glean.com -> Admin -> Tokens
GLEAN_TOKEN=your-glean-api-token
GLEAN_BASE_URL=https://yourcompany-be.glean.com

# Server
PORT=3001
NODE_ENV=development
